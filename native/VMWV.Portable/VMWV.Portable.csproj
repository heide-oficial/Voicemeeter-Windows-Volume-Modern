<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.17763.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>VMWV_Portable</RootNamespace>
    <AssemblyName>VMWV.Portable</AssemblyName>
    <ApplicationIcon>..\VMWV.App\Assets\AppIcon.ico</ApplicationIcon>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup Condition="'$(PayloadZipPath)' != ''">
    <EmbeddedResource Include="$(PayloadZipPath)" LogicalName="VoicemeeterWindowsVolumeModern.Payload.zip" />
  </ItemGroup>
</Project>
